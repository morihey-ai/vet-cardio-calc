[
  {
    "id": "mine1",
    "label": "MINE score 1",
    "type": "numeric",
    "source": "Vezzosi et al. 2021, JVIM 35:1238-1244",
    "items": [
      {
        "key": "laAo",
        "label": "左房/大動脈比（LA/Ao）",
        "rules": [
          { "maxExclusive": 1.7, "points": 1, "reason": "LA/Ao < 1.70" },
          { "min": 1.7, "max": 1.9, "points": 2, "reason": "LA/Ao 1.70-1.90" },
          { "minExclusive": 1.9, "max": 2.5, "points": 3, "reason": "LA/Ao 1.91-2.50" },
          { "minExclusive": 2.5, "points": 4, "reason": "LA/Ao > 2.50" }
        ]
      },
      {
        "key": "lviddn",
        "label": "左室拡張末期径 正規化値（LVIDDN）",
        "rules": [
          { "maxExclusive": 1.7, "points": 1, "reason": "LVIDDN < 1.70" },
          { "min": 1.7, "max": 2.0, "points": 2, "reason": "LVIDDN 1.70-2.00" },
          { "minExclusive": 2.0, "max": 2.3, "points": 3, "reason": "LVIDDN 2.01-2.30" },
          { "minExclusive": 2.3, "points": 4, "reason": "LVIDDN > 2.30" }
        ]
      },
      {
        "key": "fsPercent",
        "label": "左室内径短縮率（FS%）",
        "rules": [
          { "maxExclusive": 45, "points": 1, "reason": "FS < 45%" },
          { "min": 45, "max": 50, "points": 2, "reason": "FS 45-50%" },
          { "minExclusive": 50, "points": 3, "reason": "FS > 50%" }
        ]
      },
      {
        "key": "eVelMps",
        "label": "僧帽弁E波最大速度（E-vel）",
        "rules": [
          { "maxExclusive": 1.2, "points": 1, "reason": "E-vel < 1.20 m/s" },
          { "min": 1.2, "max": 1.5, "points": 2, "reason": "E-vel 1.20-1.50 m/s" },
          { "minExclusive": 1.5, "points": 3, "reason": "E-vel > 1.50 m/s" }
        ]
      }
    ],
    "classes": [
      { "min": 4, "max": 5, "label": "軽度（Mild）" },
      { "min": 6, "max": 7, "label": "中等度（Moderate）" },
      { "min": 8, "max": 12, "label": "重度（Severe）" },
      { "min": 13, "max": 14, "label": "末期相当（Late stage）" }
    ],
    "note": "犬MMVD向けのエコー重症度分類。予後情報の補助表示であり、治療推奨ではありません。"
  },
