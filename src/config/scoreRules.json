  {
    "id": "ph",
    "label": "PH score",
    "type": "manual",
    "source": "Chang et al. 2026, JVIM 40:aalag004",
    "items": [
      {
        "key": "phRvWall",
        "label": "右室壁肥厚（RV wall thickening）",
        "options": [
          { "value": "normal", "points": 0, "reason": "正常: RV壁がLV壁より薄い" },
          { "value": "mild", "points": 1, "reason": "軽度-中等度: RV壁がLV壁と同程度" },
          { "value": "moderateSevere", "points": 2, "reason": "中等度-重度: RV壁がLV壁より厚い" }
        ]
      },
      {
        "key": "phRvDilatation",
        "label": "右室拡大（RV dilatation）",
        "options": [
          { "value": "normal", "points": 0, "reason": "正常: RVID <= LVIDの50%" },
          { "value": "mild", "points": 2, "reason": "軽度: RVID > LVIDの50%" },
          { "value": "moderate", "points": 4, "reason": "中等度: RVID >= LVIDの75% かつ LVID未満" },
          { "value": "severe", "points": 6, "reason": "重度: RVID > LVID" }
        ]
      },
      {
        "key": "phRaEnlargement",
        "label": "右房拡大（RA enlargement）",
        "options": [
          { "value": "normal", "points": 0, "reason": "正常: RAD < LAD" },
          { "value": "mild", "points": 2, "reason": "軽度: RAD = LAD" },
          { "value": "moderate", "points": 4, "reason": "中等度: RAD > LAD かつ 1.5 x LAD未満" },
          { "value": "severe", "points": 6, "reason": "重度: RAD >= 1.5 x LAD" }
        ]
      },
      {
        "key": "phIvsFlattening",
        "label": "心室中隔扁平化（IVS flattening）",
        "options": [
          { "value": "normal", "points": 0, "reason": "正常: IVS flatteningなし" },
          { "value": "subtleMild", "points": 2, "reason": "軽度: LV側への偏位はあるが明瞭な扁平化なし" },
          { "value": "moderateSevere", "points": 4, "reason": "中等度-重度: IVSが明瞭に扁平、またはLV側へ凸" }
        ]
      },
      {
        "key": "phPaEnlargement",
        "label": "肺動脈拡大（PA enlargement / PA/Ao）",
        "options": [
          { "value": "normal", "points": 0, "reason": "正常: PA/Ao <= 1" },
          { "value": "mild", "points": 2, "reason": "軽度: PA/Ao > 1 かつ 1.5未満" },
          { "value": "moderate", "points": 4, "reason": "中等度: PA/Ao >= 1.5 かつ 2未満" },
          { "value": "severe", "points": 6, "reason": "重度: PA/Ao >= 2" }
        ]
      },
      {
        "key": "phRvotNotching",
        "label": "RVOT midsystolic notching",
        "options": [
          { "value": "normal", "points": 0, "reason": "なし: RVOT波形にmid-systolic notchingなし" },
          { "value": "abnormal", "points": 1, "reason": "あり: RVOT波形にmid-systolic notchingあり" }
        ]
      }
    ],
    "classes": [
      { "min": 0, "max": 2, "label": "PH score閾値未満" },
      { "min": 3, "max": 8, "label": "pTRV >= 3.4 m/s相当" },
      { "min": 9, "max": 25, "label": "pTRV >= 4.3 m/s相当" }
    ],
    "note": "25点満点の視覚評価スコア。LA/Ao >= 2のpostcapillary PHでは精度低下が報告されています。確定診断ではありません。"
  }
]
